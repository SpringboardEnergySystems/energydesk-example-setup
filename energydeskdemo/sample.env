ENERGYDESK_TOKEN=
ENERGYDESK_URL=https://demo-api.energydesk.no

# Source EnergyDesk instance to pull market data from
ENERGYDESK_SOURCE_URL=https://demo-api.energydesk.no
ENERGYDESK_SOURCE_TOKEN=

EXTRA_TRADERS=warrenbuffet@gmail.com, donaldtrump@gmail.com, nickleeson@gmail.com
EXTRA_TRADERS=riskmaster@gmail.com

# ---------------------------------------------------------------------------
# InfluxDB (optional)
#
# When these are set, production_loader.py writes forecasts to InfluxDB in
# addition to the appserver blob store.  If INFLUXDB_TOKEN is absent or empty
# the demo setup skips InfluxDB writes silently and continues as before.
#
# Bucket naming convention:
#   Production and sales forecasts are written to a single bucket named
#   {customer_name}_assetdata (e.g. "aademo_assetdata").  The customer_name
#   is derived from the company short_name at runtime; you do not need to set
#   it here.  The bucket is created automatically on first run.
#
# Querying from Flux (example):
#   from(bucket: "aademo_assetdata")
#     |> range(start: 2026-01-01T00:00:00Z)
#     |> filter(fn: r => r._measurement == "asset_forecast")
#     |> filter(fn: r => r.forecast_type == "production")
#     |> filter(fn: r => r.scenario == "median")
#     |> filter(fn: r => r.asset_type == "hydro")
# ---------------------------------------------------------------------------
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=
INFLUXDB_ORG=springboard
# INFLUXDB_BUCKET is the fallback bucket when customer_name cannot be derived;
# in practice production_loader.py always passes the bucket explicitly.
INFLUXDB_BUCKET=springboard_assetdata
